# .env — Агро Центр Тоҷикистон
# Скопируйте этот файл в .env и заполните значения

# ── БАЗА ДАННЫХ ──────────────────────────────
# Локально: установите PostgreSQL и создайте базу данных
DATABASE_URL="postgresql://postgres:your_password@localhost:5432/agro_centr_tj"

# ── NEXTAUTH ──────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
# Сгенерировать: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-here"

# ── GOOGLE OAUTH ──────────────────────────────
# Создайте проект на console.cloud.google.com
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ── TELEGRAM BOT ──────────────────────────────
# Токен вашего бота от @BotFather
TELEGRAM_BOT_TOKEN="your-bot-token-here"

# Chat ID администратора (получить: напишите боту /start, затем откройте:
# https://api.telegram.org/bot<TOKEN>/getUpdates и найдите "chat":{"id":...})
TELEGRAM_ADMIN_CHAT_ID="your-admin-chat-id"

# Chat ID сборщика (или группы сборщиков)
TELEGRAM_COLLECTOR_CHAT_ID="your-collector-chat-id"

# ── КАК ПОЛУЧИТЬ TELEGRAM CHAT ID ─────────────
# 1. Отправьте /start вашему боту в Telegram
# 2. Откройте в браузере: https://api.telegram.org/bot<ВАШ_ТОКЕН>/getUpdates
# 3. Найдите "chat":{"id": XXXXXX} — это и есть ваш chat_id
# 4. Для группы: добавьте бота в группу и проделайте то же самое
